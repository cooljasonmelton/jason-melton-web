---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jason Melton | Live" bgImage="https://images.unsplash.com/photo-1585699324551-f6c309eedeca?q=80&w=2000&auto=format&fit=crop">
	<h1>Live Shows</h1>
	<p>I perform standup comedy and occasionally play music. Check back here for upcoming dates and ticket links.</p>
	
	<div class="feed" style="margin-top: 2rem;">
		<article class="card">
			<div class="meta">
				<span class="collection-label">Standup</span>
				<span class="date">TBD</span>
			</div>
			<h2>More dates coming soon</h2>
			<p>Taking a quick break from the road. I'll be back on stage shortly.</p>
		</article>
	</div>
</Layout>